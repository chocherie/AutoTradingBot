# Anthropic Console → API keys → Create Key. Paste the full secret (starts with sk-ant-api03-).
# One line only: ANTHROPIC_API_KEY=<paste secret here>  (no quotes, no spaces around =)
ANTHROPIC_API_KEY=

# If Claude fails with CERTIFICATE_VERIFY_FAILED:
# - Home network with Cisco Umbrella / corporate SSL inspection: Python must trust your org CA.
#   Concatenate:  cat "$(python -c 'import certifi; print(certifi.where())')" /path/to/org-root.pem > /tmp/combo.pem
#   Then: export SSL_CERT_FILE=/tmp/combo.pem
# - Otherwise: pip install certifi  (and prefer Homebrew Python 3.12+ over Xcode CLT Python)
# SSL_CERT_FILE=

FRED_API_KEY=
FINNHUB_API_KEY=
# Optional: web dashboard (absolute path to SQLite when running Next.js locally)
# DATABASE_PATH=/path/to/AutoTradingBot/storage/trading_bot.db

# After each `python -m src.main` run, upload SQLite to Vercel Blob (dashboard stays in sync).
# DASHBOARD_DB_SYNC_URL=https://your-app.vercel.app/api/admin/sync-db
# DASHBOARD_DB_SYNC_SECRET=match-DB_UPLOAD_SECRET-on-vercel

# On Vercel (Project → Settings → Environment Variables), also set:
# BLOB_READ_WRITE_TOKEN   — from Vercel Blob store (dashboard reads/writes the blob)
# DB_UPLOAD_SECRET        — same value as DASHBOARD_DB_SYNC_SECRET (POST /api/admin/sync-db Bearer)
# Note: use a private Vercel Blob store; the app uploads with access private and reads with BLOB_READ_WRITE_TOKEN.
